<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meghan Fasano — Resume</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1a2e;
    --ink-soft: #3d3d5c;
    --ink-muted: #6b6b8a;
    --cream: #faf9f6;
    --warm-white: #f5f3ee;
    --accent: #2d5a7b;
    --accent-light: #e8f0f5;
    --rule: #c8c4ba;
    --rule-light: #e2dfd8;
    --gold: #9a7b4f;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  @page {
    size: 8.5in 11in;
    margin: 0;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #e8e5de;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
  }

  .page {
    width: 8.5in;
    min-height: 11in;
    margin: 20px auto;
    background: var(--cream);
    box-shadow: 0 4px 40px rgba(0,0,0,0.08);
    position: relative;
    overflow: hidden;
  }

  /* Decorative sidebar stripe */
  .page::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 6px;
    height: 100%;
    background: linear-gradient(180deg, var(--accent) 0%, var(--gold) 100%);
  }

  .content {
    padding: 0.55in 0.6in 0.5in 0.7in;
  }

  /* ── HEADER ── */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 14px;
    border-bottom: 2.5px solid var(--ink);
    margin-bottom: 6px;
  }

  .header-left h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 32px;
    letter-spacing: 0.5px;
    color: var(--ink);
    line-height: 1.1;
  }

  .header-left .title-line {
    font-family: 'DM Sans', sans-serif;
    font-size: 10.5px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 1.8px;
    text-transform: uppercase;
    margin-top: 5px;
  }

  .header-right {
    text-align: right;
    font-size: 9px;
    color: var(--ink-muted);
    line-height: 1.7;
    letter-spacing: 0.2px;
  }

  .header-right a {
    color: var(--ink-muted);
    text-decoration: none;
  }

  /* ── SUMMARY ── */
  .summary {
    padding: 12px 0 14px;
    border-bottom: 1px solid var(--rule-light);
  }

  .summary p {
    font-size: 9.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 100%;
  }

  /* ── STRENGTHS GRID ── */
  .strengths-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 12px 0 14px;
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: hidden;
  }

  .strength-cell {
    padding: 10px 14px;
    border-right: 1px solid var(--rule-light);
    background: var(--warm-white);
  }

  .strength-cell:last-child { border-right: none; }

  .strength-cell h4 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 5px;
  }

  .strength-cell p {
    font-size: 8.5px;
    line-height: 1.55;
    color: var(--ink-muted);
  }

  /* ── IMPACT METRICS ── */
  .metrics {
    display: flex;
    gap: 0;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--rule-light);
    padding-bottom: 13px;
  }

  .metric {
    flex: 1;
    text-align: center;
    position: relative;
  }

  .metric:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 15%;
    height: 70%;
    width: 1px;
    background: var(--rule-light);
  }

  .metric .number {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--accent);
    line-height: 1.1;
  }

  .metric .label {
    font-size: 7.5px;
    color: var(--ink-muted);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-top: 3px;
    line-height: 1.4;
    padding: 0 8px;
  }

  /* ── SECTION HEADERS ── */
  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 16px 0 10px;
  }

  .section-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
  }

  .section-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  /* ── EXPERIENCE ENTRIES ── */
  .entry {
    margin-bottom: 13px;
    page-break-inside: avoid;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 4px;
  }

  .entry-header .role {
    font-weight: 600;
    font-size: 10px;
    color: var(--ink);
    letter-spacing: 0.2px;
  }

  .entry-header .dates {
    font-size: 8.5px;
    color: var(--ink-muted);
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .entry .company {
    font-family: 'Cormorant Garamond', serif;
    font-size: 10.5px;
    font-weight: 600;
    font-style: italic;
    color: var(--accent);
    margin-bottom: 5px;
  }

  .entry ul {
    list-style: none;
    padding: 0;
  }

  .entry ul li {
    font-size: 8.8px;
    line-height: 1.55;
    color: var(--ink-soft);
    padding-left: 12px;
    position: relative;
    margin-bottom: 2.5px;
  }

  .entry ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 5.5px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    border: 1px solid var(--gold);
  }

  /* ── TWO-COLUMN FOOTER SECTIONS ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 30px;
  }

  .two-col .section-header {
    grid-column: 1 / -1;
    margin-top: 14px;
  }

  .cert-list, .edu-list {
    font-size: 8.8px;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .cert-list li, .edu-list li {
    list-style: none;
    padding-left: 12px;
    position: relative;
    margin-bottom: 1px;
  }

  .cert-list li::before, .edu-list li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 600;
  }

  .edu-list li strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── KEYWORDS ── */
  .keywords-section {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--rule-light);
  }

  .keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 6px;
  }

  .keyword-tag {
    font-size: 7.5px;
    letter-spacing: 0.4px;
    padding: 3px 9px;
    background: var(--accent-light);
    color: var(--accent);
    border-radius: 2px;
    font-weight: 500;
  }

  /* ── PRINT ── */
  @media print {
    body { background: white; }
    .page {
      margin: 0;
      box-shadow: none;
      width: 100%;
      min-height: auto;
    }
  }
</style>
</head>
